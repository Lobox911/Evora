# ---- Database (Neon) ----
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/evora?sslmode=require"

# ---- Auth (Clerk) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
